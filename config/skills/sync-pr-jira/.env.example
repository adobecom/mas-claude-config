<!-- secret-ok: env template with placeholder values, no real credentials -->
# Copy to .env on the server, fill in, chmod 600. NEVER commit .env.
# Jira uses BASIC auth (email:token), not Bearer. Both values required.
# Token: Adobe Jira → Profile → Personal Access Tokens → Create (or your SSO credential).
JIRA_PAT=
JIRA_EMAIL=
JIRA_BASE_URL=https://jira.corp.adobe.com

# GitHub token with 'repo' scope (or run `gh auth login` on the box and omit this)
GH_TOKEN=

# Set to 1 to let the unattended job apply backward moves (→ In Development).
# Leave unset/0 so backward moves are only reported, not auto-applied.
ALLOW_BACKWARD=0

# Optional: Slack incoming webhook. If set, the job pings it ONLY on failure
# (✗ / ERROR in output, or non-zero exit). A clean run stays silent.
# Create at https://api.slack.com/messaging/webhooks — leave blank to disable.
SLACK_WEBHOOK_URL=
